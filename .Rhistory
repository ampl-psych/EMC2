library(AccumulatR)
library(EMC2)
ADmat <- cbind(d=c(-.5,.5))
RDM_AA <- race_spec() |>
add_accumulator("AL1","RDM") |>
add_accumulator("AL2","RDM") |>
add_accumulator("AU1","RDM") |>
add_accumulator("AU2","RDM") |>
add_outcome("1",first_of("AL1","AU1")) |>
add_outcome("2",first_of("AL2","AU2")) |>
set_parameters() |> finalize_model()
# set_parameters() by default groups everything together
# however, you can also specify separate ones or rename them
# see ? set_parameters
# The model as is is pretty poorly identified, so hopefully the learning
# can provide some constraint
par_names(RDM_AA)
RDM_AA <- EMC2:::AccumulatR_model(RDM_AA)
mf <- function(d) {
match <- rep(FALSE, nrow(d))
match[as.character(d$S) == "1" & d$racer %in% c("AL1", "AU1")] <- TRUE
match[as.character(d$S) == "2" & d$racer %in% c("AL2", "AU2")] <- TRUE
return(factor(match))
}
type_fun <- function(d){
type <- rep("AL", nrow(d))
type[d$racer %in% c("AU1", "AU2")] <- "AU"
return(factor(type))
}
dRDM <- design(model=RDM_AA,
factors=list(subjects=1,S=1:2),Rlevels=1:2,
functions=list(lM=mf, type = type_fun),
contrast=list(lM=ADmat),
formula=list(B ~ 1, v ~ lM*type, t0 ~ 1))
pv <- EMC2::sampled_pars(dRDM)
pv[] <- c(log(1.2), log(2), .5, .2, .2, log(.3))
dat <- make_data(pv,dRDM,1000)
plot_density(dat, factors = c("S"))
dat$R <- factor(dat$R)
dat$S
dat$subjects
emc <- make_emc(dat, dRDM, type  = "single")
emc <- fit(emc)
credint(emc)
pv
# Prediction is still a bit slow in AccumulatR
pp <- predict(emc, n_cores = 10)
plot_cdf(dat, pp, factors = "S")
