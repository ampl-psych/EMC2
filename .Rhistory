functions = list(go1 = go_fun, onset = onset_fun, acc = acc_fun))
rm(list = ls())
library(EMC2)
library(AccumulatR)
load("~/Documents/2026/StopData/stim_selective/clean_data_selective_stop_pilot.Rdata")
data <- d
data <- data[,c("s", "SS", "S", "R", "RT", "SSD")]
idx <- data$S == "A" & data$R == "B" | data$S == "B" & data$R == "A"
data <- data[!idx,]
data$R <- factor(data$R)
data$S <- droplevels(data$S)
levels(data$R) <- c("A", "B", NA_character_)
colnames(data)[c(1,2, 5)] <- c("subjects", "cond", "rt")
data$cond <- factor(data$cond)
levels(data$cond) <- c("go", "ignore", "stop")
head(data)
data <- data[data$subjects == unique(data$subjects)[1],]
# check successful stop percentage
mean(is.na(data$R[data$cond == "stop"]))
plot_density(data, factors = "cond")
table(data$R, data$cond, data$S)
# data$S <- "GO"
# data$R <- is.na(data$R)
# data$R[!data$R] <- "GO"
# data$R[data$R == "TRUE"] <- NA
# data$R <- factor(data$R)
model <- race_spec() |>
add_accumulator("A", "lognormal") |>
add_accumulator("B", "lognormal") |>
add_accumulator("S1", "lognormal") |>
add_accumulator("IS", "lognormal") |>
add_accumulator("S2", "lognormal") |>
add_outcome(
"A",
first_of(
inhibit("A", by = "S1"), # Standard stop race
all_of("A", "S1", inhibit("IS", by="S2"))# stopped, then ignore branch
)
) |>
add_outcome(
"B",
first_of(
inhibit("B", by = "S1"),
all_of("B", "S1", inhibit("IS", by="S2"))# stopped, then ignore branch
)
) |>
add_outcome(
"STOP",
all_of("S1", inhibit("S2", by = "IS")),
options = list(map_outcome_to = NA_character_)
) |>
add_component("go", members = c("A", "B")) |>
add_component("stop", members = c("A", "B", "S1", "IS", "S2")) |>
set_parameters(list(m_go = c("A.m", "B.m"), s_go = c("A.s", "B.s"),
t0_go = c("A.t0", "B.t0"))) |>
finalize_model()
stop_selective <- EMC2:::AccumulatR_model(model)
go_fun <- function(data){
return(factor(data$accumulator %in% c("A", "B")))
}
onset_fun <- function(data){
onset <- data$SSD
onset[data$accumulator %in% c("A", "B")] <- 0
return(onset)
}
acc_fun <- function(data){
out <- data$accumulator
out[data$cond == "stop" & data$accumulator == "IS"] <- "bad_IS"
return(out)
}
data$component <- "go"
data$component[data$cond != "go"] <- "stop"
data$component <- factor(data$component)
rm(list = ls())
