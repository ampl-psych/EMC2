match[as.character(d$S) == "2" & d$accumulator %in% c("AL2", "AU2")] <- TRUE
return(factor(match))
}
dRDM <- design(model=RDM_AA,
factors=list(subjects=1,S=1:2),Rlevels=1:2,
functions=list(lM=mf),
contrast=list(lM=ADmat),
matchfun=function(d) d$S==d$lR,
formula=list(B ~ 1, al_v ~ lM, au_v ~ lM, t0 ~ 1))
par_names(RDM_AA)
rm(list = ls())
