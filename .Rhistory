vals <- .75
N <- 6
reps <- 1e6
prob_mat <- matrix(0, nrow = N, ncol = 2)
rownames(prob_mat) <- paste0("T", 1:6)
probs <- rep(.75, 6)
for(i in 1:N){
prob_mat[i,1] <- sum(rbinom(reps, 1, prob = probs[i]))
prob_mat[i,2] <- sum(rbinom(reps, 1, prob = 1-probs[i]))
}
prob_mat
