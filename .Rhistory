library(EMC2)
# SBC (single) object structure: list with components rank/med/bias/coverage,
# each a list with $alpha = (replicates x parameters) matrix. Combining = rbind
# $alpha across batches for every component.
combine_sbc <- function(files) {
present <- files[file.exists(files)]
if (length(present) == 0L)
stop("None of the expected result files were found:\n  ",
paste(files, collapse = "\n  "))
if (length(present) < length(files))
warning("Missing ", length(files) - length(present), " of ", length(files),
" batch files; combining the ", length(present), " present:\n  ",
paste(setdiff(files, present), collapse = "\n  "), call. = FALSE)
sbcs <- lapply(present, function(f) {
e <- new.env(parent = emptyenv())
load(f, envir = e)
if (!exists("SBC", envir = e))
stop("No `SBC` object found in ", f)
get("SBC", envir = e)
})
combined <- sbcs[[1]]
for (comp in names(combined))
combined[[comp]]$alpha <- do.call(rbind, lapply(sbcs, function(s) s[[comp]]$alpha))
attr(combined, "n_batches") <- length(present)
combined
}
report <- function(label, sbc) {
n <- nrow(sbc$rank$alpha)
message(sprintf("%s: %d replicates from %d batches; %d parameters (%s)",
label, n, attr(sbc, "n_batches"), ncol(sbc$rank$alpha),
paste(colnames(sbc$rank$alpha), collapse = ", ")))
}
setwd("~/Downloads/sbc_steven/DDM")
# --- Censoring ---------------------------------------------------------------
censor_files <- sprintf("SBC_DDM_C%d.RData", 1:5)
censor <- combine_sbc(censor_files)
report("Censoring", censor)
save(censor, file = "SBC_DDM_censor_combined.RData")
pdf("SBC_DDM_censor.pdf", width = 10, height = 8)
plot_sbc_hist(censor)
plot_sbc_ecdf(censor)
dev.off()
# --- Truncation --------------------------------------------------------------
trunc_files <- sprintf("SBC_DDM_T%d.RData", 1:5)
trunc <- combine_sbc(trunc_files)
report("Truncation", trunc)
save(trunc, file = "SBC_DDM_trunc_combined.RData")
pdf("SBC_DDM_trunc.pdf", width = 10, height = 8)
plot_sbc_hist(trunc)
plot_sbc_ecdf(trunc)
dev.off()
library(EMC2)
# Go/no-go DDM SBC (based on the DDMc censoring scripts). Withheld (nogo) trials
# have rt = NA; their likelihood is 1 - F_go(TIMEOUT). DDMGNG routes to the C++
# path (c_name = "DDMGNG"). No TC truncation/censoring for GNG.
Smat <- matrix(d=c(-1,1),ncol=1)
design_DDM <- design(Rlevels = c("left", "right"),contrasts=list(S=Smat),
factors = list(subjects = 1, S = c("left", "right")),
functions = list(
TIMEOUT = function(d) rep(2, nrow(d)),
Rnogo   = function(d) factor(rep("left",  nrow(d)), levels = c("left", "right")),
Rgo     = function(d) factor(rep("right", nrow(d)), levels = c("left", "right"))),
formula = list(v~S, a~1, t0~1, s~1, Z~1, sv~1, SZ~1, st0~1),
constants = c(s = log(1)),
model = DDMGNG)
# Go/no-go DDM SBC (based on the DDMc censoring scripts). Withheld (nogo) trials
# have rt = NA; their likelihood is 1 - F_go(TIMEOUT). DDMGNG routes to the C++
# path (c_name = "DDMGNG"). No TC truncation/censoring for GNG.
Smat <- matrix(d=c(-1,1),ncol=1)
# Go/no-go DDM SBC (based on the DDMc censoring scripts). Withheld (nogo) trials
# have rt = NA; their likelihood is 1 - F_go(TIMEOUT). DDMGNG routes to the C++
# path (c_name = "DDMGNG"). No TC truncation/censoring for GNG.
Smat <- cbind(d=c(-1,1)
)
Smat
design_DDM <- design(Rlevels = c("left", "right"),contrasts=list(S=Smat),
factors = list(subjects = 1, S = c("left", "right")),
functions = list(
TIMEOUT = function(d) rep(2, nrow(d)),
Rnogo   = function(d) factor(rep("left",  nrow(d)), levels = c("left", "right")),
Rgo     = function(d) factor(rep("right", nrow(d)), levels = c("left", "right"))),
formula = list(v~S, a~1, t0~1, s~1, Z~1, sv~1, SZ~1, st0~1),
constants = c(s = log(1)),
model = DDMGNG)
prior_DDM <- prior(design_DDM, type = "single",
pmean = c(0,1,1, log(.8), log(.3), qnorm(.5), log(.1), qnorm(.05), log(.05)),
psd = c(.15,.15, .15, .1, .05, .15, .15, .15))
pv=sampled_pars(design_DDM)
pv[]=c(0,1,1, log(.8), log(.3), qnorm(.5), log(.1), qnorm(.05), log(.05)
)
