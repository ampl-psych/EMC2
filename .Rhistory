ADmat <- cbind(d = c(-.5, .5))
stop_trial <- function(data){
factor(data$cond == "stop")
}
des <- design(data = data,
formula = list(m_go ~ lM + S, s_go ~ lM, t0_go ~ 1, S1.m ~ 1, S2.m ~ 1, IS.m ~ stop, IS.s ~ stop, S1.s ~ 1, S2.s ~ 1),
model = stop_selective,
matchfun = matchfun,
functions = list(onset = onset_fun, lM = matchfun, stop = stop_trial),
contrasts = list(lM = ADmat))
mapped_pars(des, EMC2::sampled_pars(des))
emc <- make_emc(data, des, type = "single", compress = T)
emc <- fit(emc, fileName = "stim_selective_niek_s1.RData", iter = 500)
pp <- predict(emc, n_cores = 10)
SSD_fun <- function(data){
SSD <- data$SSD
SSD[data$cond != "stop"] <- Inf
return(SSD)
}
plot_cdf(data, pp, factors = c("cond"))
data$resp <- factor(!is.na(data$R))
pp$resp <- factor(!is.na(pp$R))
plot_density(data, pp, factors = c("cond"), defective_factor = "resp")
credint(emc)
