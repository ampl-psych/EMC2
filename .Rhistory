# SBC (single) object: list with components rank/med/bias/coverage, each a list
# with $alpha = (replicates x parameters) matrix. Combine = rbind $alpha.
combine_sbc <- function(files) {
present <- files[file.exists(files)]
if (length(present) == 0L) return(NULL)
if (length(present) < length(files))
warning("Missing ", length(files) - length(present), " of ", length(files),
" batch files; combining the ", length(present), " present.", call. = FALSE)
sbcs <- lapply(present, function(f) {
e <- new.env(parent = emptyenv()); load(f, envir = e)
if (!exists("SBC", envir = e)) stop("No `SBC` object in ", f)
get("SBC", envir = e)
})
combined <- sbcs[[1]]
for (comp in names(combined))
combined[[comp]]$alpha <- do.call(rbind, lapply(sbcs, function(s) s[[comp]]$alpha))
attr(combined, "n_batches") <- length(present)
combined
}
for (model in c("RDM", "LBA", "LNR")) {
files <- sprintf("SBC_%s_g%d.RData", model, 1:5)
sbc <- combine_sbc(files)
if (is.null(sbc)) {
message(model, ": no batch files found, skipping.")
next
}
n <- nrow(sbc$rank$alpha)
message(sprintf("%s: %d replicates from %d batches; params: %s", model, n,
attr(sbc, "n_batches"), paste(colnames(sbc$rank$alpha), collapse = ", ")))
save(sbc, file = sprintf("SBC_%s_gng_combined.RData", model))
pdf(sprintf("SBC_%s_gng.pdf", model), width = 10, height = 8)
plot_sbc_hist(sbc)
plot_sbc_ecdf(sbc)
dev.off()
